{
  "expo": {
    "name": "BasExpo",
    "slug": "basexpo-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "basexpo",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.basexpo.visitor",
      "infoPlist": {
        "NSCameraUsageDescription": "QR kod taramak için kamera gereklidir.",
        "NSPhotoLibraryUsageDescription": "Profil fotoğrafı seçmek için gereklidir."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a1a"
      },
      "package": "com.basexpo.visitor",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-barcode-scanner",
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "QR kod taramak için kamera gereklidir."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
